{
  "name": "assignment-1",
  "version": "1.0.0",
  "description": "This is a template repository for the first assignment in BVD 103 at McMaster Continuing Education.",
  "main": "index.js",
  "scripts": {
    "generate": "./generate-openapi.sh",
    "start-server": "npm run generate && tsx src/server.ts",
    "lint": "npm run generate && eslint . --ext .ts",
    "fix-lint": "npm run generate && eslint . --ext .ts --fix",
    "fmt": "npm run generate && eslint . --fix",
    "typecheck": "npm run generate && tsc --noEmit",
    "test": "npm run generate && vitest",
    "test:watch": "npm run generate && vitest --watch",
    "test:ci": "npm run generate && vitest run",
    "compose:up": "docker-compose up",
    "compose:down": "docker-compose down"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/router": "^15.1.1",
    "koa": "^2.16.3",
    "koa-bodyparser": "^4.4.1",
    "koa-qs": "^3.0.0",
    "koa-zod-router": "^2.3.0",
    "mongodb": "7.0",
    "tsx": "^4.19.1",
    "zod": "^3.25.76",
    "koa2-swagger-ui": "^5.11.0",
    "tsoa": "^6.6.0"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/koa__cors": "^5.0.0",
    "@types/koa__router": "^12.0.4",
    "@types/koa-qs": "^2.0.3",
    "@types/node": "^22.19.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "mongodb-memory-server": "^11.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.54.0",
    "vite": "^6.3.5",
    "vitest": "^4.0.18",
    "@openapitools/openapi-generator-cli": "^2.20.5",
    "@types/koa-bodyparser": "^4.3.12"
  }
}
