        "koa-qs": "^3.0.0",
        "koa-zod-router": "^2.3.0",
        "koa2-swagger-ui": "^5.12.0",
        "mongodb": "^7.0.0",
        "tsoa": "^7.0.0-alpha.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@openapitools/openapi-generator-cli": "^2.30.2",
