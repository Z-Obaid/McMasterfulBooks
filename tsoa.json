{
  "entryFile": "src/server.ts",
  "noImplicitAdditionalProperties": "throw-on-extras",
  "controllerPathGlobs": ["src/**/*.route.ts"],
  "spec": {
    "outputDirectory": "build",
    "basePath": "/api",
    "specVersion": 3
  },
  "routes": {
    "routesDir": "build",
    "middleware": "koa"
  }
}