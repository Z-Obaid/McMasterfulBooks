{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "index.ts",
    "adapter/**/*.ts",
    "scripts/**/*.mjs"
  ],
  "exclude": [
    "node_modules",
    "build",
    "client",
    "services",
    "src"
  ]
}